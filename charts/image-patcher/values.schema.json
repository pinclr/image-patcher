{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "image-patcher chart values",
  "type": "object",
  "required": ["image"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["registry", "repository"],
      "properties": {
        "registry": {
          "type": "string",
          "minLength": 1,
          "description": "Container registry that hosts the controller image (e.g. registry.example.com). Must be set; bare repositories are not pulled from docker.io by accident."
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["IfNotPresent", "Always", "Never"]
        }
      }
    },
    "registryCredentials": {
      "type": "array",
      "description": "Registry username/password pairs. The chart base64-encodes each into a docker config.json auths map and provisions the image-registry-secret Secret (key config.json) automatically.",
      "items": {
        "type": "object",
        "required": ["registry", "username", "password"],
        "properties": {
          "registry": {
            "type": "string",
            "minLength": 1,
            "description": "Registry host the creds authenticate to (e.g. registry.example.com)."
          },
          "username": {
            "type": "string",
            "minLength": 1
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "kaniko": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "registry": {
              "type": "string"
            },
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
