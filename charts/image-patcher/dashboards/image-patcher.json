{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Build overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Build rate (per minute)",
      "description": "Builds reaching a terminal state, broken down by result. Stacked.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "bars",
            "stacking": {"mode": "normal", "group": "A"},
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "failed"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "succeeded"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          }
        ]
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (result) (rate(image_patcher_builds_total[$__rate_interval])) * 60",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Success rate (24h)",
      "description": "succeeded / total over the last 24h.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.9},
              {"color": "green", "value": 0.98}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(image_patcher_builds_total{result=\"succeeded\"}[24h])) / clamp_min(sum(rate(image_patcher_builds_total[24h])), 1e-9)"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Total builds (all-time, this controller)",
      "description": "Counter resets when the controller pod restarts -- use rate() for trend.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(image_patcher_builds_total)"
        }
      ]
    },
    {
      "type": "bargauge",
      "id": 4,
      "title": "Top images by build count",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "continuous-GrYlRd"}
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (image) (image_patcher_builds_total))",
          "legendFormat": "{{image}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Build latency",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Build duration percentiles",
      "description": "Wall time from Kaniko Job startTime to terminal phase.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "heatmap",
      "id": 6,
      "title": "Build duration heatmap",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"scaleDistribution": {"type": "linear"}}}
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {"scheme": "Spectral", "mode": "scheme", "steps": 64},
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "yAxis": {"unit": "s", "decimals": 0},
        "legend": {"show": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Controller health",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Reconcile failures by reason",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {"drawStyle": "bars", "stacking": {"mode": "normal", "group": "A"}, "fillOpacity": 70}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (reason) (rate(image_patcher_reconcile_failures_total[$__rate_interval])) * 60",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Workqueue depth",
      "description": "Pending reconciles. Sustained non-zero = controller can't keep up.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 20}}
      },
      "options": {
        "legend": {"showLegend": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "workqueue_depth{name=\"imagepatch\"}",
          "legendFormat": "depth"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Reconcile p95",
      "description": "controller-runtime reconcile loop duration p95. Excludes build wall time.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "options": {
        "legend": {"showLegend": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"imagepatch\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "row",
      "id": 105,
      "title": "End-to-end latency",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "E2E percentiles (CR creation -> terminal)",
      "description": "image_patcher_e2e_seconds: wall time from ImagePatch creationTimestamp to terminal phase. Includes reconciler queue, Job scheduling, Kaniko, push, status update. Always recorded -- dedup hits land in the smallest bucket.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le) (rate(image_patcher_e2e_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(image_patcher_e2e_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(image_patcher_e2e_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "E2E p95 split by cache state",
      "description": "p95 of image_patcher_e2e_seconds, split by dedup_hit (controller short-circuit) and build_layer_cache_disabled (per-CR opt out of Kaniko --cache=true). Compare curves to see which cache tier moves end-to-end time.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, dedup_hit, build_layer_cache_disabled) (rate(image_patcher_e2e_seconds_bucket[$__rate_interval])))",
          "legendFormat": "dedup_hit={{dedup_hit}} layer_disabled={{build_layer_cache_disabled}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 104,
      "title": "In flight & failure breakdown",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "panels": []
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Active builds",
      "description": "ImagePatch CRs currently in Phase=Running. Refreshed every 30s by the in-process phase aggregator.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 37},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "orange", "value": 10}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "image_patcher_active_builds"
        }
      ]
    },
    {
      "type": "piechart",
      "id": 14,
      "title": "ImagePatches by phase",
      "description": "Snapshot of all ImagePatch CRs grouped by Status.Phase.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 10, "x": 6, "y": 37},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Succeeded"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "Failed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "Running"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "Pending"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]}
        ]
      },
      "options": {
        "displayLabels": ["name", "value"],
        "legend": {"displayMode": "list", "placement": "right", "showLegend": true, "values": ["value"]},
        "pieType": "pie",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "image_patcher_imagepatches",
          "legendFormat": "{{phase}}",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "Build failures by reason",
      "description": "Failed builds split by jobFailureReason: deadline_exceeded / backoff_limit_exceeded / build_error.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 37},
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {"drawStyle": "bars", "stacking": {"mode": "normal", "group": "A"}, "fillOpacity": 80}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (failure_reason) (rate(image_patcher_builds_total{result=\"failed\"}[$__rate_interval])) * 60",
          "legendFormat": "{{failure_reason}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["image-patcher", "kaniko"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Image Patcher",
  "uid": "image-patcher",
  "version": 1,
  "weekStart": ""
}
