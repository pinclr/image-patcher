{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Build overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Build rate (per minute)",
      "description": "Builds reaching a terminal state, broken down by result. Stacked.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "bars",
            "stacking": {"mode": "normal", "group": "A"},
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "failed"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "succeeded"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          }
        ]
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (result) (rate(image_patcher_builds_total[$__rate_interval])) * 60",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Success rate (24h)",
      "description": "succeeded / total over the last 24h.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.9},
              {"color": "green", "value": 0.98}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(image_patcher_builds_total{result=\"succeeded\"}[24h])) / clamp_min(sum(rate(image_patcher_builds_total[24h])), 1e-9)"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Total builds (all-time, this controller)",
      "description": "Counter resets when the controller pod restarts -- use rate() for trend.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(image_patcher_builds_total)"
        }
      ]
    },
    {
      "type": "bargauge",
      "id": 4,
      "title": "Top images by build count",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "continuous-GrYlRd"}
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (image) (image_patcher_builds_total))",
          "legendFormat": "{{image}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Build latency",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Build duration percentiles",
      "description": "Wall time from Kaniko Job startTime to terminal phase.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "heatmap",
      "id": 6,
      "title": "Build duration heatmap",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"scaleDistribution": {"type": "linear"}}}
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {"scheme": "Spectral", "mode": "scheme", "steps": 64},
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "yAxis": {"unit": "s", "decimals": 0},
        "legend": {"show": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (le) (rate(image_patcher_build_duration_seconds_bucket[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Controller health",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Reconcile failures by reason",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {"drawStyle": "bars", "stacking": {"mode": "normal", "group": "A"}, "fillOpacity": 70}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (reason) (rate(image_patcher_reconcile_failures_total[$__rate_interval])) * 60",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Workqueue depth",
      "description": "Pending reconciles. Sustained non-zero = controller can't keep up.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 20}}
      },
      "options": {
        "legend": {"showLegend": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "workqueue_depth{name=\"imagepatch\"}",
          "legendFormat": "depth"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Reconcile p95",
      "description": "controller-runtime reconcile loop duration p95. Excludes build wall time.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "options": {
        "legend": {"showLegend": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"imagepatch\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "row",
      "id": 103,
      "title": "Pull-cache PVC",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "panels": []
    },
    {
      "type": "gauge",
      "id": 10,
      "title": "Pull-cache usage",
      "description": "kubelet_volume_stats_used_bytes / capacity. Requires kubelet PVC stats in Prometheus.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 28},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max(kubelet_volume_stats_used_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"}) / max(kubelet_volume_stats_capacity_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Pull-cache used / capacity",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28},
      "fieldConfig": {
        "defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "fillOpacity": 10}}
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max(kubelet_volume_stats_used_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max(kubelet_volume_stats_capacity_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"})",
          "legendFormat": "capacity"
        }
      ]
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Predicted days until full",
      "description": "Linear extrapolation of the last 6h of available bytes. Negative or empty = trend is downward (filling) or no data.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 28},
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 3},
              {"color": "green", "value": 14}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max(kubelet_volume_stats_available_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"}) / clamp_min(max(deriv(kubelet_volume_stats_used_bytes{persistentvolumeclaim=~\".*kaniko-pull-cache\"}[6h])), 1) / 86400"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["image-patcher", "kaniko"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Image Patcher",
  "uid": "image-patcher",
  "version": 1,
  "weekStart": ""
}
