# Environment configuration for image-builder
# Copy this file and customize for your environment:
#   cp config-example.env config-myenv.env
# Usage:
#   make docker-build docker-push deploy ENV_FILE=config-myenv.env

# --- build stage ---
# Controller manager image
BUILDER_IMAGE_NAME=image-builder:latest
# Container tool (docker, podman, etc.)
CONTAINER_TOOL=docker
# Platforms for multi-arch buildx (used by `make docker-buildx`)
PLATFORM=linux/amd64

# --- deploy stage ---
# Default registry for pushing patched images (used when spec.targetImage is not set)
DEFAULT_IMAGE_REGISTRY=
# Kaniko executor image (override for air-gapped or mirrored environments)
KANIKO_IMAGE_NAME=gcr.io/kaniko-project/executor:v1.23.2
