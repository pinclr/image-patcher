# Environment configuration for image-patch-operator (ysyb)
# Usage:
#   make docker-build docker-push deploy ENV_FILE=config-ysyb.env

# --- build stage ---
# Controller manager image
BUILDER_IMAGE_NAME=registry.luna.ogpu.cloud/image-patch-system/image-patch-operator:v0.1.1
# Container tool (docker, podman, etc.)
CONTAINER_TOOL=docker
# Target platform for docker build
PLATFORM=linux/amd64

# --- deploy stage ---
# Default registry for pushing patched images (used when spec.targetImage is not set)
DEFAULT_IMAGE_REGISTRY=registry.luna.ogpu.cloud/patched-images
# Kaniko executor image (override for air-gapped or mirrored environments)
KANIKO_IMAGE_NAME=registry.luna.ogpu.cloud/image-patch-system/kaniko-executor:v1.23.2
